{
  "name": "fnjq",
  "version": "0.1.0",
  "description": "jq, but it runs in your browser. A lightweight jq-subset implementation in pure TypeScript.",
  "keywords": [
    "jq",
    "json",
    "query",
    "filter",
    "transform",
    "json-query",
    "json-path",
    "json-transform",
    "browser",
    "serverless"
  ],
  "license": "MIT",
  "author": "fnrhombus",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnrhombus/fnjq"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "bugs": {
    "url": "https://github.com/fnrhombus/fnjq/issues"
  },
  "homepage": "https://github.com/fnrhombus/fnjq#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
